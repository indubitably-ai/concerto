#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="${CONCERTO_RUNNER_IMAGE:-concerto-codex-runner:latest}"
PARENT_ROOT="$(cd .. && pwd)"

case "$(uname -m)" in
  arm64|aarch64)
    TARGET_TRIPLE="aarch64-unknown-linux-musl"
    ;;
  x86_64)
    TARGET_TRIPLE="x86_64-unknown-linux-musl"
    ;;
  *)
    echo "Unsupported host architecture: $(uname -m)" >&2
    exit 1
    ;;
esac

BINARY_ROOT="${CONCERTO_RUNNER_BINARY_ROOT:-$PARENT_ROOT/codex-indubitably/codex-rs/target/$TARGET_TRIPLE/release}"
BINARY_PATH="$BINARY_ROOT/codex"

if [[ ! -x "$BINARY_PATH" ]]; then
  echo "Expected executable runner binary at $BINARY_PATH" >&2
  echo "Build codex-indubitably for $TARGET_TRIPLE before building the runner image." >&2
  exit 1
fi

docker build \
  --build-context codex_bin="$BINARY_ROOT" \
  -f "$PARENT_ROOT/concerto/docker/runner.Dockerfile" \
  -t "$IMAGE_NAME" \
  "$PARENT_ROOT/concerto"
